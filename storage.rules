rules_version = '2';

// ---------------------------------------------------------------------------
// Marudhara Exam — Production Firebase Storage Security Rules
// ---------------------------------------------------------------------------
// Deploy with:  firebase deploy --only storage
// (or paste into Firebase Console -> Storage -> Rules -> Publish).
//
// The website's PDFs/images (question papers, notes, banners) are hosted
// on GitHub Pages / external links, not the Firebase Storage bucket — the
// client code never calls the Storage SDK. This bucket must therefore stay
// closed by default; it only exists because every Firebase project has one.
// If Storage uploads are added later, restrict the new path explicitly to
// isAdmin() writes the same way firestore.rules does, rather than opening
// this file up broadly.
// ---------------------------------------------------------------------------

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() in [
          'jmdseller2025@gmail.com'
        ];
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
